// Prisma Schema for Tryhardly - Guild-Inspired Quest Gig Marketplace

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  displayName   String
  avatarUrl     String?
  bio           String?

  // Gamification
  level         Int       @default(1)
  xp            Int       @default(0)
  adventurerClass UserClass @default(WARRIOR)

  // Reputation & role
  reputationScore Int     @default(0)
  verified        Boolean @default(false)
  role            String  @default("USER")

  // Stats
  totalQuestsPosted    Int @default(0)
  totalQuestsCompleted Int @default(0)

  // Guild membership (optional)
  guildId       String?
  guild         Guild?   @relation("GuildMembers", fields: [guildId], references: [id])

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  questsGiven        Quest[]           @relation("QuestGiver")
  questsCompleted    Quest[]           @relation("AssignedAdventurer")
  applications       Application[]
  guildMemberships   GuildMember[]
  achievements       UserAchievement[]
  messages           Message[]
  reviews            Review[]
  notifications      Notification[]
  ledGuilds          Guild[]           @relation("GuildLeader")

  @@index([email])
  @@index([username])
}

enum UserClass {
  WARRIOR      // Developer
  MAGE         // Designer
  ROGUE        // Writer
  CLERIC       // Support
}

// ─── Quest ───────────────────────────────────────────────────────────────────

model Quest {
  id              String          @id @default(uuid())
  title           String
  description     String
  category        QuestCategory
  difficulty      QuestDifficulty

  // Payment
  reward          Decimal
  currency        String          @default("USD")

  // Status
  status          QuestStatus     @default(OPEN)

  // XP Reward
  xpReward        Int

  // Metadata
  tags            String[]
  maxApplications Int?

  // Relations
  questGiverId         String
  questGiver           User    @relation("QuestGiver", fields: [questGiverId], references: [id])

  assignedAdventurerId String?
  assignedAdventurer   User?   @relation("AssignedAdventurer", fields: [assignedAdventurerId], references: [id])

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deadline        DateTime?
  completedAt     DateTime?

  // Child relations
  applications    Application[]
  milestones      Milestone[]
  reviews         Review[]

  @@index([questGiverId])
  @@index([assignedAdventurerId])
  @@index([status])
  @@index([category])
}

enum QuestCategory {
  WEB_DEVELOPMENT
  MOBILE_DEV
  DESIGN
  WRITING
  MARKETING
  DATA_SCIENCE
  OTHER
}

enum QuestDifficulty {
  NOVICE
  APPRENTICE
  JOURNEYMAN
  EXPERT
  MASTER
  LEGENDARY
}

enum QuestStatus {
  OPEN
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

// ─── Application ─────────────────────────────────────────────────────────────

model Application {
  id            String            @id @default(uuid())
  questId       String
  quest         Quest             @relation(fields: [questId], references: [id])
  adventurerId  String
  adventurer    User              @relation(fields: [adventurerId], references: [id])

  coverLetter   String
  proposedRate  Decimal?
  status        ApplicationStatus @default(PENDING)

  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([questId])
  @@index([adventurerId])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Guild ───────────────────────────────────────────────────────────────────

model Guild {
  id              String   @id @default(uuid())
  name            String   @unique
  tag             String   @unique
  description     String
  badgeUrl        String?
  banner          String?
  isPublic        Boolean  @default(true)

  // Leader
  leaderId        String
  leader          User     @relation("GuildLeader", fields: [leaderId], references: [id])

  // Stats
  reputationScore Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  members         GuildMember[]
  guildUsers      User[]   @relation("GuildMembers")
}

model GuildMember {
  id        String    @id @default(uuid())
  guildId   String
  guild     Guild     @relation(fields: [guildId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  role      GuildRole @default(MEMBER)
  joinedAt  DateTime  @default(now())

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
}

enum GuildRole {
  LEADER
  OFFICER
  MEMBER
}

// ─── Milestone ───────────────────────────────────────────────────────────────

model Milestone {
  id          String          @id @default(uuid())
  questId     String
  quest       Quest           @relation(fields: [questId], references: [id])

  title       String
  description String
  amount      Decimal

  status      MilestoneStatus @default(PENDING)
  completedAt DateTime?

  createdAt   DateTime        @default(now())

  @@index([questId])
}

enum MilestoneStatus {
  PENDING
  COMPLETED
  PAID
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(uuid())
  questId     String
  quest       Quest    @relation(fields: [questId], references: [id])
  reviewerId  String
  reviewer    User     @relation(fields: [reviewerId], references: [id])

  rating      Int
  comment     String

  createdAt   DateTime @default(now())

  @@index([questId])
  @@index([reviewerId])
}

// ─── Achievement ─────────────────────────────────────────────────────────────

model Achievement {
  id          String            @id @default(uuid())
  name        String            @unique
  description String
  icon        String
  xpReward    Int

  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// ─── Message ─────────────────────────────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  recipientId String

  content     String
  read        Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([recipientId])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])

  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
}

enum NotificationType {
  QUEST_APPLICATION
  QUEST_ACCEPTED
  QUEST_COMPLETED
  MILESTONE_COMPLETED
  NEW_MESSAGE
  ACHIEVEMENT_UNLOCKED
  LEVEL_UP
}
