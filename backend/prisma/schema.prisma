// Prisma Schema for Tryhardly - Guild-Inspired Quest Gig Marketplace

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  displayName   String
  avatarUrl     String?
  bio           String?

  // Gamification
  level         Int       @default(1)
  xp            Int       @default(0)
  adventurerClass UserClass @default(WARRIOR)

  // Reputation & role
  reputationScore Int     @default(0)
  verified        Boolean @default(false)
  role            String  @default("USER")

  // Stats
  totalQuestsPosted    Int @default(0)
  totalQuestsCompleted Int @default(0)

  // Stripe integration
  stripeAccountId   String?
  stripeCustomerId  String?

  // Guild membership (optional)
  guildId       String?
  guild         Guild?   @relation("GuildMembers", fields: [guildId], references: [id])

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  questsGiven        Quest[]           @relation("QuestGiver")
  questsCompleted    Quest[]           @relation("AssignedAdventurer")
  applications       Application[]
  guildMemberships   GuildMember[]
  achievements       UserAchievement[]
  messages           Message[]
  reviews            Review[]          @relation("ReviewAuthor")
  reviewsReceived    Review[]          @relation("ReviewSubject")
  notifications      Notification[]
  ledGuilds          Guild[]           @relation("GuildLeader")
  passwordResetTokens PasswordResetToken[]
  reportsFiled       Report[]          @relation("ReportsFiled")
  reportsResolved    Report[]          @relation("ReportsResolved")

  @@index([email])
  @@index([username])
}

enum UserClass {
  WARRIOR      // Developer
  MAGE         // Designer
  ROGUE        // Writer
  CLERIC       // Support
}

// ─── Quest ───────────────────────────────────────────────────────────────────

model Quest {
  id              String          @id @default(uuid())
  title           String
  description     String
  category        QuestCategory
  difficulty      QuestDifficulty

  // Payment
  reward          Decimal
  currency        String          @default("USD")

  // Status
  status          QuestStatus     @default(OPEN)

  // Escrow / payment tracking
  escrowStatus    EscrowStatus    @default(NONE)
  paymentIntentId String?

  // XP Reward
  xpReward        Int

  // Metadata
  tags            String[]
  maxApplications Int?

  // Relations
  questGiverId         String
  questGiver           User    @relation("QuestGiver", fields: [questGiverId], references: [id])

  assignedAdventurerId String?
  assignedAdventurer   User?   @relation("AssignedAdventurer", fields: [assignedAdventurerId], references: [id])

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deadline        DateTime?
  completedAt     DateTime?

  // Child relations
  applications    Application[]
  milestones      Milestone[]
  reviews         Review[]
  messages        Message[]

  @@index([questGiverId])
  @@index([assignedAdventurerId])
  @@index([status])
  @@index([category])
}

enum QuestCategory {
  WEB_DEVELOPMENT
  MOBILE_DEV
  DESIGN
  WRITING
  MARKETING
  DATA_SCIENCE
  OTHER
}

enum QuestDifficulty {
  NOVICE
  APPRENTICE
  JOURNEYMAN
  EXPERT
  MASTER
  LEGENDARY
}

enum QuestStatus {
  OPEN
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum EscrowStatus {
  NONE
  PENDING
  FUNDED
  PARTIALLY_RELEASED
  RELEASED
  REFUNDED
}

// ─── Application ─────────────────────────────────────────────────────────────

model Application {
  id            String            @id @default(uuid())
  questId       String
  quest         Quest             @relation(fields: [questId], references: [id])
  adventurerId  String
  adventurer    User              @relation(fields: [adventurerId], references: [id])

  coverLetter   String
  proposedRate  Decimal?
  status        ApplicationStatus @default(PENDING)

  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([questId])
  @@index([adventurerId])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Guild ───────────────────────────────────────────────────────────────────

model Guild {
  id              String   @id @default(uuid())
  name            String   @unique
  tag             String   @unique
  description     String
  badgeUrl        String?
  banner          String?
  isPublic        Boolean  @default(true)

  // Leader
  leaderId        String
  leader          User     @relation("GuildLeader", fields: [leaderId], references: [id])

  // Stats
  reputationScore Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  members         GuildMember[]
  guildUsers      User[]   @relation("GuildMembers")
}

model GuildMember {
  id        String    @id @default(uuid())
  guildId   String
  guild     Guild     @relation(fields: [guildId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  role      GuildRole @default(MEMBER)
  joinedAt  DateTime  @default(now())

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
}

enum GuildRole {
  LEADER
  OFFICER
  MEMBER
}

// ─── Milestone ───────────────────────────────────────────────────────────────

model Milestone {
  id          String          @id @default(uuid())
  questId     String
  quest       Quest           @relation(fields: [questId], references: [id])

  title       String
  description String
  amount      Decimal

  status      MilestoneStatus @default(PENDING)
  completedAt DateTime?

  createdAt   DateTime        @default(now())

  @@index([questId])
}

enum MilestoneStatus {
  PENDING
  COMPLETED
  PAID
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(uuid())
  questId     String
  quest       Quest    @relation(fields: [questId], references: [id])
  reviewerId  String
  reviewer    User     @relation("ReviewAuthor", fields: [reviewerId], references: [id])

  // The user being reviewed (counterparty on the quest). Nullable to preserve
  // any pre-existing rows that predate this column.
  revieweeId  String?
  reviewee    User?    @relation("ReviewSubject", fields: [revieweeId], references: [id])

  rating      Int
  comment     String

  createdAt   DateTime @default(now())

  // One review per reviewer per quest — prevents duplicate reviews.
  @@unique([questId, reviewerId])
  @@index([questId])
  @@index([reviewerId])
  @@index([revieweeId])
}

// ─── Achievement ─────────────────────────────────────────────────────────────

model Achievement {
  id          String            @id @default(uuid())
  name        String            @unique
  description String
  icon        String
  xpReward    Int

  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// ─── Message ─────────────────────────────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  recipientId String

  // Optional quest link so messages can be grouped into a per-quest thread.
  // Nullable to preserve any existing rows and direct (non-quest) messages.
  questId     String?
  quest       Quest?   @relation(fields: [questId], references: [id])

  content     String
  read        Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([recipientId])
  @@index([questId])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])

  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
}

enum NotificationType {
  QUEST_APPLICATION
  QUEST_ACCEPTED
  QUEST_COMPLETED
  MILESTONE_COMPLETED
  NEW_MESSAGE
  ACHIEVEMENT_UNLOCKED
  LEVEL_UP
}

// ─── Password Reset ──────────────────────────────────────────────────────────

// Stores only a SHA-256 hash of the reset token, never the token itself, so a
// database leak cannot be used to reset accounts. Tokens are single-use and
// short-lived (expiry enforced at the application layer).
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── Report / Dispute ────────────────────────────────────────────────────────

model Report {
  id          String       @id @default(uuid())

  reporterId  String
  reporter    User         @relation("ReportsFiled", fields: [reporterId], references: [id])

  targetType  ReportTargetType
  // Free-form id of the reported entity (quest id, user id, or message id).
  targetId    String

  reason      ReportReason
  details     String?
  status      ReportStatus @default(OPEN)

  // Admin who resolved/dismissed the report, if any.
  resolvedById String?
  resolvedBy   User?       @relation("ReportsResolved", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  resolutionNote String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
}

enum ReportTargetType {
  QUEST
  USER
  MESSAGE
}

enum ReportReason {
  SPAM
  HARASSMENT
  SCAM
  INAPPROPRIATE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

// ─── Lead ────────────────────────────────────────────────────────────────────
// Low-friction acquisition: captures intent before account creation.
//   - JOB_REQUEST: a poster describing work they need done (from /request-help).
//   - WORKER_ALERT: a worker signing up for work alerts (from /work-alerts).
// Leads are admin-triage items, NOT live quests. An admin can later convert a
// JOB_REQUEST into a real Quest; convertedQuestId records that linkage.
model Lead {
  id          String     @id @default(uuid())

  type        LeadType
  status      LeadStatus @default(NEW)

  // Contact info (no account required).
  name        String
  email       String
  phone       String?

  // Common location field (city / ZIP / neighborhood, free-form).
  location    String?

  // Type-specific structured fields. Optional so one model serves both types.
  // JOB_REQUEST:
  title       String?
  description String?
  category    String?
  budget      String?
  timeline    String?
  photoUrls   String[]   @default([])
  // WORKER_ALERT:
  skills      String[]   @default([])
  availability String?
  hasTools    Boolean    @default(false)

  // Catch-all for any extra fields without a migration.
  payload     Json?

  // Admin triage / conversion tracking. handledById is the admin user id
  // (free-form, mirrors Report.targetId — avoids extra User back-relations).
  handledById       String?
  handledAt         DateTime?
  adminNote         String?
  convertedQuestId  String?

  // No-account claim/manage link. Only a SHA-256 hash of the claim token is
  // stored, never the raw token, so a DB leak can't be used to view/edit a lead.
  // Used only for JOB_REQUEST leads. The token lets a requester view and lightly
  // edit their own submission without an account; expiry is enforced in the app.
  claimTokenHash      String?   @unique
  claimTokenExpiresAt DateTime?
  claimedAt           DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([type, status])
  @@index([status])
  @@index([createdAt])
}

enum LeadType {
  JOB_REQUEST
  WORKER_ALERT
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  IGNORED
}
