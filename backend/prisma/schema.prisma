// Prisma Schema for Tryhardly - Guild-Inspired Quest Gig Marketplace

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  displayName   String
  avatarUrl     String?
  bio           String?

  // Gamification
  level         Int       @default(1)
  xp            Int       @default(0)
  adventurerClass UserClass @default(WARRIOR)

  // Reputation & role
  reputationScore Int     @default(0)
  verified        Boolean @default(false)
  role            String  @default("USER")

  // Professionalism layer. Additive and nullable: a worker may pledge to the
  // public Code of Craft. Null means "not pledged" — we never imply a pledge
  // that didn't happen. The pledged-at timestamp doubles as the proof.
  codeOfCraftPledgedAt DateTime?

  // Stats
  totalQuestsPosted    Int @default(0)
  totalQuestsCompleted Int @default(0)

  // Stripe integration
  stripeAccountId   String?
  stripeCustomerId  String?

  // Guild membership (optional)
  guildId       String?
  guild         Guild?   @relation("GuildMembers", fields: [guildId], references: [id])

  // Optional professional/contractor profile fields (all nullable, additive).
  businessName    String?
  serviceArea     String?
  yearsExperience Int?

  // Worker-curated "favorite" skill slugs surfaced on the public profile. Purely
  // additive; defaults to empty so existing rows are unaffected. The badge tier
  // for each skill is always derived from real SkillRating data, never from this
  // list — this only controls which skills the worker chooses to feature.
  favoriteSkills  String[] @default([])

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  questsGiven        Quest[]           @relation("QuestGiver")
  questsCompleted    Quest[]           @relation("AssignedAdventurer")
  applications       Application[]
  guildMemberships   GuildMember[]
  achievements       UserAchievement[]
  messages           Message[]
  reviews            Review[]          @relation("ReviewAuthor")
  reviewsReceived    Review[]          @relation("ReviewSubject")
  notifications      Notification[]
  ledGuilds          Guild[]           @relation("GuildLeader")
  passwordResetTokens PasswordResetToken[]
  reportsFiled       Report[]          @relation("ReportsFiled")
  reportsResolved    Report[]          @relation("ReportsResolved")
  credentials        ProfessionalCredential[] @relation("CredentialOwner")
  credentialsVerified ProfessionalCredential[] @relation("CredentialVerifier")
  skillRatingsReceived SkillRating[]          @relation("SkillRatingSubject")
  skillRatingsGiven    SkillRating[]          @relation("SkillRatingAuthor")
  proofOfWork          ProofOfWork[]          @relation("ProofOwner")
  servicePackages      ServicePackage[]       @relation("ServicePackageOwner")
  deletionRequests     AccountDeletionRequest[] @relation("DeletionRequester")
  deletionRequestsHandled AccountDeletionRequest[] @relation("DeletionHandler")

  @@index([email])
  @@index([username])
}

enum UserClass {
  WARRIOR      // Builder
  MAGE         // Craftsperson
  ROGUE        // Scout
  CLERIC       // Helper
  HAULER       // Hauler
  FIXER        // Fixer
}

// ─── Quest ───────────────────────────────────────────────────────────────────

model Quest {
  id              String          @id @default(uuid())
  title           String
  description     String
  category        QuestCategory
  difficulty      QuestDifficulty

  // Payment
  reward          Decimal
  currency        String          @default("USD")

  // Status
  status          QuestStatus     @default(OPEN)

  // Escrow / payment tracking
  escrowStatus    EscrowStatus    @default(NONE)
  paymentIntentId String?
  // Marketplace destination-charge flow (Connect): the Stripe Checkout Session
  // that collected the client payment, took the 12% platform fee, and routed the
  // net to the worker's connected account. Additive/nullable so existing rows and
  // the legacy payment path are unaffected.
  checkoutSessionId String?

  // ─── Non-escrow payment state (authorize → complete → capture → payout) ──────
  // Tracks the manual-capture destination-charge lifecycle for the marketplace
  // Checkout flow. This is intentionally SEPARATE from the legacy `escrowStatus`
  // enum above: the new flow never holds funds, so it has no FUNDED/RELEASED
  // states. At Checkout completion the card is AUTHORIZED (not charged); the
  // charge is CAPTURED when the task is confirmed complete; the authorization is
  // CANCELED if the job is canceled before capture. All fields default/null so
  // existing rows and the legacy escrow path are unaffected.
  paymentStatus       PaymentStatus @default(NONE)
  paymentAuthorizedAt DateTime?
  paymentCapturedAt   DateTime?
  paymentCanceledAt   DateTime?

  // XP Reward
  xpReward        Int

  // Metadata
  tags            String[]
  maxApplications Int?

  // Relations
  questGiverId         String
  questGiver           User    @relation("QuestGiver", fields: [questGiverId], references: [id])

  assignedAdventurerId String?
  assignedAdventurer   User?   @relation("AssignedAdventurer", fields: [assignedAdventurerId], references: [id])

  // ─── Work completion protocol ───────────────────────────────────────────────
  // Additive, backward-compatible fields backing the worker→client completion
  // handshake. The worker submits a completion request (notes + proof image
  // URLs, no file storage — same convention as ProofOfWork), which moves the
  // quest to IN_REVIEW. The quest giver then either confirms (→ COMPLETED) or
  // requests changes (→ back to IN_PROGRESS). All fields are nullable / default
  // 0 so existing rows are unaffected and the legacy "owner marks complete"
  // path keeps working unchanged.
  completionNote        String?
  // Worker-supplied proof image URLs for the completion request (no file storage).
  completionProofUrls   String[]  @default([])
  // Set when the worker submits a completion request; cleared semantics are not
  // needed — confirmedAt / status carry the final state. Doubles as a reliability
  // signal (request → confirm turnaround, on-time vs. deadline).
  completionRequestedAt DateTime?
  // Set when the quest giver confirms the completion request.
  completionConfirmedAt DateTime?
  // How many times the giver sent the work back for changes. A reliability
  // signal; never used to auto-penalize (mirrors the non-destructive progression
  // design). The most recent change note the giver left for the worker.
  changeRequestCount    Int       @default(0)
  changeRequestNote     String?

  // ─── Recurring booking template ─────────────────────────────────────────────
  // Additive, backward-compatible fields letting a client mark a job as recurring
  // (e.g. weekly mowing) so the repeat relationship stays on-platform instead of
  // the lead being lost after one booking. This is purely a scheduling/visibility
  // template: it does NOT charge, hold, or pre-authorize any money. Each actual
  // occurrence is its own quest with the normal per-task marketplace payout when
  // the client confirms completion. All fields default to the non-recurring case
  // so existing rows are unaffected.
  isRecurring         Boolean            @default(false)
  // Cadence + interval describe the repeat rhythm. interval is a multiplier on the
  // cadence (e.g. WEEKLY + 2 = every two weeks); defaults to 1.
  recurrenceCadence   RecurrenceCadence?
  recurrenceInterval  Int                @default(1)
  // Optional bounds — a client may cap the series by date or by a number of
  // occurrences. Null on both means open-ended ("until cancelled").
  recurrenceEndDate   DateTime?
  recurrenceCount     Int?
  // Best-effort hint for when the next occurrence is suggested. Advisory only;
  // nothing auto-charges or auto-posts off this. Recomputed when an occurrence
  // is generated.
  nextOccurrenceAt    DateTime?

  // Self-relation linking generated occurrences back to the template quest. A
  // template (isRecurring=true) is the parent; manually generated next-occurrence
  // quests point at it via recurrenceParentId.
  recurrenceParentId  String?
  recurrenceParent    Quest?  @relation("RecurrenceSeries", fields: [recurrenceParentId], references: [id])
  recurrenceChildren  Quest[] @relation("RecurrenceSeries")

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deadline        DateTime?
  completedAt     DateTime?

  // Child relations
  applications    Application[]
  milestones      Milestone[]
  reviews         Review[]
  messages        Message[]
  skillRatings    SkillRating[]
  proofOfWork     ProofOfWork[]

  @@index([questGiverId])
  @@index([assignedAdventurerId])
  @@index([status])
  @@index([category])
  @@index([recurrenceParentId])
  @@index([isRecurring])
}

enum RecurrenceCadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum QuestCategory {
  WEB_DEVELOPMENT
  MOBILE_DEV
  DESIGN
  WRITING
  MARKETING
  DATA_SCIENCE
  OTHER
}

enum QuestDifficulty {
  NOVICE
  APPRENTICE
  JOURNEYMAN
  EXPERT
  MASTER
  LEGENDARY
}

enum QuestStatus {
  OPEN
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum EscrowStatus {
  NONE
  PENDING
  FUNDED
  PARTIALLY_RELEASED
  RELEASED
  REFUNDED
}

// Non-escrow marketplace payment lifecycle (authorize → complete → capture →
// payout). Distinct from EscrowStatus: there is no fund-holding state. The card
// is AUTHORIZED at Checkout, CAPTURED when the task is confirmed complete, or
// CANCELED if the booking is canceled before capture. CAPTURE_FAILED records a
// capture attempt that errored (e.g. an expired authorization) so it can be
// surfaced/retried without losing the prior state.
enum PaymentStatus {
  NONE
  AUTHORIZED
  CAPTURED
  CANCELED
  CAPTURE_FAILED
}

// ─── Application ─────────────────────────────────────────────────────────────

model Application {
  id            String            @id @default(uuid())
  questId       String
  quest         Quest             @relation(fields: [questId], references: [id])
  adventurerId  String
  adventurer    User              @relation(fields: [adventurerId], references: [id])

  // Made optional alongside the detailed-bid fields below: a worker can now
  // submit a structured bid (amounts, materials, timeline) without a free-text
  // cover letter. Existing rows already have a value, so this is backward
  // compatible. The controller still requires *some* content (cover letter or a
  // bid amount) so an empty application can't be created.
  coverLetter   String?
  proposedRate  Decimal?
  status        ApplicationStatus @default(PENDING)

  // ─── Detailed bid fields ─────────────────────────────────────────────────────
  // Additive, backward-compatible fields backing the multi-bid worker workflow.
  // A worker can submit a full bid for a job: a total amount split into material
  // and labor estimates, an itemized material list, a timeline, and an optional
  // request for a remote or on-site walkthrough before committing. The legacy
  // "express interest" application (coverLetter + optional proposedRate) keeps
  // working unchanged — every field below is nullable / defaulted so existing
  // rows and the simple apply path are unaffected. None of these fields touch
  // payment mechanics: money is only authorized later, after the poster selects a
  // bid, via the existing manual-capture Checkout flow (which reads quest.reward).
  //
  // Total bid (what the worker is quoting for the whole job). When the poster
  // accepts this bid, this becomes the amount the job is paid at.
  bidAmount            Decimal?
  // Cost breakdown the worker is quoting. Advisory detail for the poster; the
  // payable figure is bidAmount.
  materialCostEstimate Decimal?
  laborCostEstimate    Decimal?
  estimatedLaborHours  Decimal?
  // Itemized material list as JSON: array of
  // { name, quantity, unit, estimatedCost, notes }. Stored as JSON so the
  // structure can evolve without further migrations; null when not provided.
  materialItems        Json?
  // Free-text list of tools / equipment / materials the worker will bring.
  toolsNeeded          String?
  // When the worker can do the work (free text / availability).
  timeline             String?
  // Walkthrough request: whether the worker wants to see the site first, how
  // (remote video call or in-person on-site review), and the times they propose.
  walkthroughRequested Boolean           @default(false)
  walkthroughType      WalkthroughType   @default(NONE)
  // Proposed walkthrough times — free text or JSON list of slots.
  proposedWalkthroughTimes String?
  // Bid breakdown notes / notes to the client.
  bidNotes             String?
  // Contractor/legal qualification acknowledgement for contractor-scale jobs.
  // Worker affirms they are responsible for only accepting work they are legally
  // qualified to perform. Does NOT imply TryHardly verifies legal status.
  legalQualificationAck Boolean          @default(false)

  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([questId])
  @@index([adventurerId])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// How a worker wants to review the job site before/while bidding.
//   NONE      — no walkthrough requested
//   REMOTE    — remote/virtual walkthrough (video call, photos, live screen)
//   IN_PERSON — on-site review / in-person visit
enum WalkthroughType {
  NONE
  REMOTE
  IN_PERSON
}

// ─── Guild ───────────────────────────────────────────────────────────────────

model Guild {
  id              String   @id @default(uuid())
  name            String   @unique
  tag             String   @unique
  description     String
  badgeUrl        String?
  banner          String?
  isPublic        Boolean  @default(true)

  // Leader
  leaderId        String
  leader          User     @relation("GuildLeader", fields: [leaderId], references: [id])

  // Stats
  reputationScore Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  members         GuildMember[]
  guildUsers      User[]   @relation("GuildMembers")
}

model GuildMember {
  id        String    @id @default(uuid())
  guildId   String
  guild     Guild     @relation(fields: [guildId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  role      GuildRole @default(MEMBER)
  joinedAt  DateTime  @default(now())

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
}

enum GuildRole {
  LEADER
  OFFICER
  MEMBER
}

// ─── Milestone ───────────────────────────────────────────────────────────────

model Milestone {
  id          String          @id @default(uuid())
  questId     String
  quest       Quest           @relation(fields: [questId], references: [id])

  title       String
  description String
  amount      Decimal

  status      MilestoneStatus @default(PENDING)
  completedAt DateTime?

  createdAt   DateTime        @default(now())

  @@index([questId])
}

enum MilestoneStatus {
  PENDING
  COMPLETED
  PAID
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(uuid())
  questId     String
  quest       Quest    @relation(fields: [questId], references: [id])
  reviewerId  String
  reviewer    User     @relation("ReviewAuthor", fields: [reviewerId], references: [id])

  // The user being reviewed (counterparty on the quest). Nullable to preserve
  // any pre-existing rows that predate this column.
  revieweeId  String?
  reviewee    User?    @relation("ReviewSubject", fields: [revieweeId], references: [id])

  rating      Int
  comment     String

  createdAt   DateTime @default(now())

  // Per-skill ratings attached to this review (optional, additive).
  skillRatings SkillRating[]

  // One review per reviewer per quest — prevents duplicate reviews.
  @@unique([questId, reviewerId])
  @@index([questId])
  @@index([reviewerId])
  @@index([revieweeId])
}

// ─── Skill Rating ─────────────────────────────────────────────────────────────
// A client's rating of a specific skill the worker performed on a completed job
// (e.g. "mowing", "fencing", "hauling"). Aggregated to derive per-skill badge
// tiers (Bronze/Silver/Gold/Platinum) on the worker's profile. Badge tiers are
// always computed from these rows — never denormalized — so they cannot go stale
// or be faked. Fully additive: no existing flow depends on this table.
model SkillRating {
  id          String   @id @default(uuid())

  // The completed quest the skill was performed on.
  questId     String
  quest       Quest    @relation(fields: [questId], references: [id])

  // The review this rating was submitted alongside, when applicable. Nullable so
  // skill ratings can also be recorded independently of a written review.
  reviewId    String?
  review      Review?  @relation(fields: [reviewId], references: [id])

  // Who rated (client) and who is being rated (worker).
  raterId     String
  rater       User     @relation("SkillRatingAuthor", fields: [raterId], references: [id])
  workerId    String
  worker      User     @relation("SkillRatingSubject", fields: [workerId], references: [id])

  // Normalized skill identity. `skillSlug` is the stable key used for grouping;
  // `skillName` is the human-friendly label captured at rating time.
  skillSlug   String
  skillName   String

  rating      Int      // 1–5

  createdAt   DateTime @default(now())

  // One rating per skill per rater per quest — prevents duplicate skill ratings.
  @@unique([questId, raterId, skillSlug])
  @@index([workerId])
  @@index([workerId, skillSlug])
  @@index([questId])
}

// ─── Achievement ─────────────────────────────────────────────────────────────

model Achievement {
  id          String            @id @default(uuid())
  name        String            @unique
  description String
  icon        String
  xpReward    Int

  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// ─── Message ─────────────────────────────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  recipientId String

  // Optional quest link so messages can be grouped into a per-quest thread.
  // Nullable to preserve any existing rows and direct (non-quest) messages.
  questId     String?
  quest       Quest?   @relation(fields: [questId], references: [id])

  content     String
  read        Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([recipientId])
  @@index([questId])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])

  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
}

enum NotificationType {
  QUEST_APPLICATION
  QUEST_ACCEPTED
  QUEST_COMPLETED
  MILESTONE_COMPLETED
  NEW_MESSAGE
  ACHIEVEMENT_UNLOCKED
  LEVEL_UP
  CREDENTIAL_VERIFIED
  CREDENTIAL_REJECTED
  COMPLETION_SUBMITTED
  COMPLETION_CONFIRMED
  COMPLETION_CHANGES_REQUESTED
}

// ─── Password Reset ──────────────────────────────────────────────────────────

// Stores only a SHA-256 hash of the reset token, never the token itself, so a
// database leak cannot be used to reset accounts. Tokens are single-use and
// short-lived (expiry enforced at the application layer).
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── Report / Dispute ────────────────────────────────────────────────────────

model Report {
  id          String       @id @default(uuid())

  reporterId  String
  reporter    User         @relation("ReportsFiled", fields: [reporterId], references: [id])

  targetType  ReportTargetType
  // Free-form id of the reported entity (quest id, user id, or message id).
  targetId    String

  reason      ReportReason
  details     String?
  status      ReportStatus @default(OPEN)

  // Admin who resolved/dismissed the report, if any.
  resolvedById String?
  resolvedBy   User?       @relation("ReportsResolved", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  resolutionNote String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
}

enum ReportTargetType {
  QUEST
  USER
  MESSAGE
}

enum ReportReason {
  SPAM
  HARASSMENT
  SCAM
  INAPPROPRIATE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

// ─── Professional Credential ────────────────────────────────────────────────
// Contractor credibility signals a user attaches to their public profile:
// licenses, insurance, certifications, etc. Submissions start PENDING and are
// only shown publicly as "verified" after an admin reviews them. Verification
// means TryHardly reviewed the submitted details — it is NOT an independent
// guarantee of legal compliance.
model ProfessionalCredential {
  id              String           @id @default(uuid())

  userId          String
  user            User             @relation("CredentialOwner", fields: [userId], references: [id], onDelete: Cascade)

  type            CredentialType
  title           String
  issuer          String?
  credentialNumber String?
  // Jurisdiction the credential applies to (e.g. "CA", "Federal", "Shasta County").
  jurisdiction    String?
  expirationDate  DateTime?
  // User-provided link to proof. We store only URLs — no document storage.
  proofUrl        String?
  notes           String?

  status          CredentialStatus @default(PENDING)

  // Admin review trail.
  verifiedById    String?
  verifiedBy      User?            @relation("CredentialVerifier", fields: [verifiedById], references: [id])
  verifiedAt      DateTime?
  rejectionReason String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([status])
}

enum CredentialType {
  LICENSE
  INSURANCE
  CERTIFICATION
  BOND
  BACKGROUND_CHECK
  TRADE_MEMBERSHIP
  OTHER
}

enum CredentialStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

// ─── ProofOfWork ──────────────────────────────────────────────────────────────
// A worker-curated, honest gallery of past work shown on the public profile.
// Additive and backward-compatible. We store only URLs (no file storage), in
// keeping with the credential model. Images are worker-supplied — the platform
// never fabricates proof. An optional questId links an item to a real quest the
// worker actually worked on; it is purely informational and not required.
model ProofOfWork {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation("ProofOwner", fields: [userId], references: [id], onDelete: Cascade)

  // Optional link to a real quest. SetNull on delete so removing a quest never
  // destroys the worker's gallery item — it just drops the linkage.
  questId     String?
  quest       Quest?   @relation(fields: [questId], references: [id], onDelete: SetNull)

  title       String
  description String?
  // Worker-supplied image URLs (e.g. a hosted photo link). No file storage.
  imageUrls   String[] @default([])
  // Free-form skill tags the worker associates with this work.
  skillTags   String[] @default([])

  // Worker controls whether the item appears on their public profile.
  visible     Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([questId])
}

// ─── ServicePackage ─────────────────────────────────────────────────────────
// A repeatable, local service listing a worker publishes (e.g. "Dump Run —
// Pickup Truck Load", "2-Hour Yard Cleanup"). Job posters browse these and tap
// "Request this service", which routes into the existing /request-help intake
// with the package as context. A ServicePackage is a LISTING, never a payment:
// no money is charged, held, or authorized here. Payment still happens later in
// the normal job → bid → worker-selection → capture flow. Additive and
// backward-compatible: every field has a default or is nullable, and the model
// is brand new, so existing rows and the Stripe/manual-capture flow are
// untouched.
model ServicePackage {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation("ServicePackageOwner", fields: [userId], references: [id], onDelete: Cascade)

  title       String
  // Free-form category slug aligned with the public jobCategories list (yard,
  // hauling, moving, handyman, cleaning, painting, pressure, other). Kept as a
  // string rather than the legacy software-oriented QuestCategory enum so it
  // matches the physical-gig taxonomy the rest of the app browses on.
  category    String
  description String?

  // Pricing is informational only — it sets expectations on the listing and is
  // never a charge. `priceType` says how to read `startingPrice`; QUOTE_NEEDED
  // means no number is shown.
  priceType     ServicePriceType @default(STARTING_AT)
  // Decimal so currency math stays exact, matching Quest.reward. Nullable for
  // QUOTE_NEEDED listings that intentionally show no price.
  startingPrice Decimal?
  currency      String           @default("USD")

  // What's included in the base scope of the service.
  includedScope   String?
  // Optional add-ons, exclusions and materials policy. Free-form text so a
  // worker can describe them naturally; no structured pricing is implied.
  addOns          String?
  exclusions      String?
  materialsPolicy String?

  // Where the worker will travel for this service (city, ZIPs, radius) and when
  // they're generally available. Free-form text, Redding-first.
  serviceArea  String?
  availability String?
  // Tools/equipment the worker brings (e.g. "Pickup truck + dolly provided").
  toolsProvided String?

  // Optional single hero photo URL (worker-supplied link; no file storage, in
  // keeping with credentials/proof-of-work).
  imageUrl String?

  // Worker controls whether the listing is publicly visible. Defaults to false
  // so a freshly created package isn't published until the worker is ready.
  active   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([active])
  @@index([category])
}

enum ServicePriceType {
  STARTING_AT
  FLAT_RATE
  HOURLY
  QUOTE_NEEDED
}

// ─── Lead ────────────────────────────────────────────────────────────────────
// Low-friction acquisition: captures intent before account creation.
//   - JOB_REQUEST: a poster describing work they need done (from /request-help).
//   - WORKER_ALERT: a worker signing up for work alerts (from /work-alerts).
// Leads are admin-triage items, NOT live quests. An admin can later convert a
// JOB_REQUEST into a real Quest; convertedQuestId records that linkage.
model Lead {
  id          String     @id @default(uuid())

  type        LeadType
  status      LeadStatus @default(NEW)

  // Contact info (no account required).
  name        String
  email       String
  phone       String?

  // Common location field (city / ZIP / neighborhood, free-form).
  location    String?

  // Type-specific structured fields. Optional so one model serves both types.
  // JOB_REQUEST:
  title       String?
  description String?
  category    String?
  budget      String?
  timeline    String?
  photoUrls   String[]   @default([])
  // Recurrence intent captured on the public help request (e.g. weekly mowing).
  // Scheduling/visibility only: nothing here charges, holds, or pre-authorizes
  // money. These mirror the Quest recurrence template fields so an admin can
  // carry the intent straight into a recurring quest at conversion. All fields
  // default to the non-recurring case, so existing leads are unaffected.
  isRecurring        Boolean            @default(false)
  recurrenceCadence  RecurrenceCadence?
  recurrenceInterval Int                @default(1)
  recurrenceEndDate  DateTime?
  recurrenceCount    Int?
  // WORKER_ALERT:
  skills      String[]   @default([])
  availability String?
  hasTools    Boolean    @default(false)

  // Worker-alert delivery + matching preferences. All additive and default to
  // the pre-existing behavior (email on, SMS off, no budget bounds) so existing
  // worker-alert leads are unaffected.
  //
  //   emailAlertsOptIn — when false, the worker is on the list but won't be
  //     emailed about matching jobs. Defaults true (existing leads keep getting
  //     emails, matching the behavior they signed up for).
  //   smsAlertsOptIn   — explicit opt-in to text alerts. Stored only; no SMS is
  //     ever sent because no SMS provider is configured. Surfaced in the UI as
  //     "text alerts coming soon". smsConsentAt records when consent was given.
  //   budgetMin/Max    — the worker's desired pay range in whole dollars. Used
  //     by matching to skip jobs whose budget falls entirely below the worker's
  //     floor (a conservative, opt-in narrowing — null means "no preference").
  emailAlertsOptIn Boolean   @default(true)
  smsAlertsOptIn   Boolean   @default(false)
  smsConsentAt     DateTime?
  budgetMin        Int?
  budgetMax        Int?

  // Acquisition attribution. `source` is the primary launch-channel label
  // (e.g. redding, facebook-requester, flyer-worker), captured from the form's
  // ?source= query param. `utm` holds any UTM/ref params as a small JSON blob so
  // we can measure which channels drive job requests and worker alerts without a
  // column per param. Both are optional and additive — leads without attribution
  // keep working unchanged.
  source      String?
  utm         Json?

  // Catch-all for any extra fields without a migration.
  payload     Json?

  // Admin triage / conversion tracking. handledById is the admin user id
  // (free-form, mirrors Report.targetId — avoids extra User back-relations).
  handledById       String?
  handledAt         DateTime?
  adminNote         String?
  convertedQuestId  String?

  // No-account claim/manage link. Only a SHA-256 hash of the claim token is
  // stored, never the raw token, so a DB leak can't be used to view/edit a lead.
  // Used only for JOB_REQUEST leads. The token lets a requester view and lightly
  // edit their own submission without an account; expiry is enforced in the app.
  claimTokenHash      String?   @unique
  claimTokenExpiresAt DateTime?
  claimedAt           DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Worker-alert match notifications. A JOB_REQUEST lead is the "job" side; a
  // WORKER_ALERT lead is the "worker" side. Both relations point at this table
  // so we can dedupe and count notifications from either direction.
  jobNotifications    LeadMatchNotification[] @relation("JobLeadNotifications")
  workerNotifications LeadMatchNotification[] @relation("WorkerLeadNotifications")

  @@index([type, status])
  @@index([status])
  @@index([createdAt])
  @@index([source])
}

// Records that a worker-alert lead was emailed about a specific job-request lead.
// Purely additive: backs the /work-alerts matching feature without altering any
// existing flow. The unique [jobLeadId, workerLeadId] pair guarantees a worker
// is never emailed twice for the same job, even under retries/races.
model LeadMatchNotification {
  id           String   @id @default(uuid())

  jobLeadId    String
  jobLead      Lead     @relation("JobLeadNotifications", fields: [jobLeadId], references: [id], onDelete: Cascade)

  workerLeadId String
  workerLead   Lead     @relation("WorkerLeadNotifications", fields: [workerLeadId], references: [id], onDelete: Cascade)

  // Denormalized for quick audit/export without joining back to the worker lead.
  email        String

  status       LeadMatchStatus @default(SENT)

  createdAt    DateTime @default(now())
  sentAt       DateTime?

  @@unique([jobLeadId, workerLeadId])
  @@index([jobLeadId])
  @@index([workerLeadId])
}

enum LeadMatchStatus {
  SENT
  FAILED
}

enum LeadType {
  JOB_REQUEST
  WORKER_ALERT
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  IGNORED
}

// ─── Account Deletion Request ─────────────────────────────────────────────────
// Google Play requires a way for users to request account/data deletion. A
// hard delete is unsafe here: a user is referenced by quests, reviews, messages,
// payments, and Stripe records, and removing the row would orphan or break those
// histories. So a logged-in user files a deletion request, which support/admin
// reviews and actions (anonymize/remove) out of band. The request itself is the
// auditable record that the user asked. At most one PENDING request per user.
model AccountDeletionRequest {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation("DeletionRequester", fields: [userId], references: [id])

  // Snapshot of contact info at request time so support can still reach the
  // user even if the account is later anonymized.
  email       String
  reason      String?

  status      DeletionRequestStatus @default(PENDING)

  handledById String?
  handledBy   User?    @relation("DeletionHandler", fields: [handledById], references: [id])
  handledAt   DateTime?
  handlerNote String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([userId])
}

enum DeletionRequestStatus {
  PENDING
  COMPLETED
  CANCELLED
}
