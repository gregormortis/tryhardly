# Backend Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tryhardly?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Redis (optional — needed for Socket.io scaling & caching)
REDIS_URL="redis://localhost:6379"

# Error reporting (optional). Backend error reporting is OFF by default and is a
# no-op unless BOTH a DSN is set here AND the optional @sentry/node package is
# installed (npm install @sentry/node). See docs/MONITORING.md.
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
# SENTRY_ENVIRONMENT="production"
# SENTRY_TRACES_SAMPLE_RATE="0"

# Email (mailer abstraction)
# EMAIL_PROVIDER selects how transactional emails are delivered:
#   log    -> writes the rendered email to server logs (default in development)
#   noop   -> silently drops emails (default in production until a provider is set)
#   resend -> sends real emails via the Resend API (requires RESEND_API_KEY)
# With log/noop, no real emails are ever sent.
EMAIL_PROVIDER="log"
# The From address/name used on outgoing email. For "resend", the domain must be
# a verified sending domain in your Resend account.
EMAIL_FROM="TryHardly <no-reply@tryhardly.com>"

# Resend (https://resend.com) — required only when EMAIL_PROVIDER="resend".
# If EMAIL_PROVIDER=resend but RESEND_API_KEY is unset, the mailer logs a warning
# and falls back to the safe default provider (log in dev, noop in production).
# RESEND_API_KEY="re_..."

# To integrate a different provider later (SendGrid/Postmark/SES), add its
# credentials here and implement the EmailProvider in src/services/mailerService.ts:
#   SENDGRID_API_KEY="SG...."        # example
#   POSTMARK_SERVER_TOKEN="..."      # example
