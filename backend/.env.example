# Backend Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tryhardly?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Optional live-mode credentials. When set, the webhook endpoint verifies
# incoming signatures against BOTH STRIPE_WEBHOOK_SECRET and
# STRIPE_LIVE_WEBHOOK_SECRET, so one endpoint can accept test and live events.
# Each secret is the signing secret of its OWN Stripe Dashboard webhook endpoint.
# STRIPE_LIVE_SECRET_KEY="sk_live_..."
# STRIPE_LIVE_WEBHOOK_SECRET="whsec_..."

# Redis (optional — needed for Socket.io scaling & caching)
REDIS_URL="redis://localhost:6379"

# Error reporting (optional). Backend error reporting is OFF by default and is a
# no-op unless BOTH a DSN is set here AND the optional @sentry/node package is
# installed (npm install @sentry/node). See docs/MONITORING.md.
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
# SENTRY_ENVIRONMENT="production"
# SENTRY_TRACES_SAMPLE_RATE="0"

# Email (mailer abstraction)
# EMAIL_PROVIDER selects how transactional emails are delivered:
#   log    -> writes the rendered email to server logs (default in development)
#   noop   -> silently drops emails (default in production until a provider is set)
#   resend -> sends real emails via the Resend API (requires RESEND_API_KEY)
# With log/noop, no real emails are ever sent.
EMAIL_PROVIDER="log"
# The From address/name used on outgoing email. For "resend", the domain must be
# a verified sending domain in your Resend account.
EMAIL_FROM="TryHardly <no-reply@tryhardly.com>"

# Resend (https://resend.com) — required only when EMAIL_PROVIDER="resend".
# If EMAIL_PROVIDER=resend but RESEND_API_KEY is unset, the mailer logs a warning
# and falls back to the safe default provider (log in dev, noop in production).
# RESEND_API_KEY="re_..."

# SUPPORT_EMAIL — OPTIONAL internal inbox alerted (best-effort) when a user
# requests account deletion. The admin deletion-requests queue is the source of
# truth, so this is purely a courtesy notification. Leave it UNSET until you have
# a real, deliverable inbox: set it only to an address whose domain has valid MX
# records. (As of this writing tryhardly.com has no MX, so support@tryhardly.com
# cannot receive mail — do not set it to that.) When unset, no support alert is
# sent and deletions are actioned entirely from the admin queue.
# SUPPORT_EMAIL="ops@yourdomain.com"

# Worker-alert matching: when a new job request comes in, TryHardly emails up to
# this many matching worker-alert leads (city + skill match). Defaults to 20.
# Jobs with no category use a tighter internal cap. Set 0/blank to use the default.
# WORKER_ALERT_MAX_EMAILS="20"

# Twilio SMS (worker text alerts) — OPTIONAL and DISABLED by default.
# SMS is sent ONLY when ALL three vars below are set. If any is missing, SMS is
# disabled gracefully (a safe no-op) and email alerts continue to work normally.
# Even when configured, a worker is texted only if they have explicitly opted in
# (smsAlertsOptIn), have a valid phone, and a recorded SMS consent timestamp.
#   TWILIO_ACCOUNT_SID  -> your Twilio account SID (starts with "AC...")
#   TWILIO_AUTH_TOKEN   -> your Twilio auth token (secret; never logged)
#   TWILIO_FROM_NUMBER  -> the sending number in E.164 (e.g. +15555550123), OR a
#                          Messaging Service SID (starts with "MG...")
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# TWILIO_FROM_NUMBER="+15555550123"
#
# STOP/opt-out handling: this app has NO inbound SMS webhook. Outbound alerts
# include "Reply STOP to opt out." but the app does not process replies. To be
# compliant in production you MUST rely on Twilio's built-in STOP handling for
# the sender (default on US long codes / toll-free numbers, and configurable on
# a Messaging Service via TWILIO_FROM_NUMBER="MG..."). Do not enable SMS in
# production without confirming STOP handling is active on the Twilio side.

# To integrate a different provider later (SendGrid/Postmark/SES), add its
# credentials here and implement the EmailProvider in src/services/mailerService.ts:
#   SENDGRID_API_KEY="SG...."        # example
#   POSTMARK_SERVER_TOKEN="..."      # example
