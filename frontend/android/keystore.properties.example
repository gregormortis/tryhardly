# Android upload-keystore signing config — TEMPLATE ONLY.
#
# Copy this file to `keystore.properties` (same directory) and fill in real values,
# OR set the equivalent TRYHARDLY_UPLOAD_* environment variables instead.
#
# The real keystore.properties and any *.jks / *.keystore files are gitignored and
# must NEVER be committed. See frontend/MOBILE_APP.md for full instructions.

# Path to your upload keystore. Relative paths are resolved from frontend/android/.
storeFile=upload-keystore.jks

# Password for the keystore file.
storePassword=CHANGE_ME

# Alias of the key inside the keystore (must match what you passed to keytool).
keyAlias=upload

# Password for that key (often the same as storePassword).
keyPassword=CHANGE_ME
